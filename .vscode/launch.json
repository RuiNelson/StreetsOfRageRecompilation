{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SoR (Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/sor",
            "args": [
                "--runSor",
                "--rom",
                "${workspaceFolder}/rom/SOR.bin",
                "--silent"
            ],
            "cwd": "${workspaceFolder}/build",
            "stopAtEntry": false,
            "preLaunchTask": "cmake build",
            "MIMode": "lldb"
        }
    ]
}
